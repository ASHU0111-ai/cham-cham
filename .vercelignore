# Vercel ignore patterns

# Dependencies
node_modules
npm-debug.log
yarn-error.log
.pnpm-debug.log

# Source files (already built)
src
*.tsx
*.ts

# Development files
.env
.env.*.local
.env.development

# Version control
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Build artifacts to exclude
.dist
dist

# OS files
.DS_Store
Thumbs.db

# Documentation
README.md
docs

# Test files
*.test.ts
*.spec.ts
__tests__

# Config files (not needed in production)
.eslintrc.json
.prettierrc
.prettierignore
tsconfig.json
vite.config.ts
