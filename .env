# Local Development Environment for TanStack Start

# ===== SERVER-SIDE CONFIGURATION =====
NODE_ENV=development
PORT=8080
HOST=localhost

# ===== CLIENT-SIDE CONFIGURATION (VITE_ prefix = exposed to browser) =====

# Application
VITE_APP_NAME=Newborn Princess Website
VITE_APP_URL=http://localhost:8080

# GitHub Repository
VITE_GITHUB_REPO=https://github.com/ASHU0111-ai/cham-cham.git

# Website Metadata
VITE_SITE_TITLE=Welcome to Our Princess
VITE_SITE_DESCRIPTION=A beautiful website celebrating the arrival of our precious newborn princess

# Media Configuration
VITE_MUSIC_PATH=/music.mp3
VITE_MUSIC_TITLE=pretty little baby

# Feature Flags
VITE_GALLERY_ENABLED=true
VITE_MESSAGES_ENABLED=true
VITE_ANIMATIONS_ENABLED=true

# UI Configuration
VITE_ANIMATION_DURATION=0.6
VITE_DEFAULT_THEME=light

# Analytics (Optional)
VITE_ANALYTICS_ENABLED=false
VITE_GA_ID=

# Social Media (Optional)
VITE_INSTAGRAM_URL=
VITE_FACEBOOK_URL=
VITE_WHATSAPP_URL=

# Contact Information (Optional)
VITE_CONTACT_EMAIL=
VITE_CONTACT_PHONE=
